# AI Startup Environment Variables
# Copy this to .env and fill in your values

# Security - Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# MongoDB Connection
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/ai_startup?retryWrites=true&w=majority

# Redis Connection
REDIS_URL=redis://localhost:6379/0

# Groq API Key
GROQ_API_KEY=gsk_your_groq_api_key_here

# App Settings
APP_NAME=AI Startup
DEBUG=false
